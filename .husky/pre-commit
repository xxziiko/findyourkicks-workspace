#!/usr/bin/env sh

# 1. Biome lint + format
echo "🔍 Biome 규칙을 적용합니다..."
if npx lint-staged; then
  echo "✅ Biome 검사 완료."
else
  echo "❌ Biome 검사 실패."
  exit 1
fi

# 2. TypeScript 타입 체크
echo "🔍 TypeScript 타입 체크 중..."
if npx tsc --noEmit; then
  echo "✅ TypeScript 타입 체크 완료."
else
  echo "❌ TypeScript 타입 체크 실패."
  exit 1
fi

echo "🎉 pre-commit 검사 완료!"
exit 0