#!/usr/bin/env sh

# 1. 프로젝트 빌드
echo "🔍 프로젝트 빌드 중..."
if pnpm run build; then
  echo "✅ 빌드 완료."
else
  echo "❌ 빌드 실패."
  exit 1
fi

# 2. E2E 테스트 (admin)
echo "🔍 E2E 테스트 실행 중..."
# 기존 dev 서버를 종료해 Playwright가 새 서버를 시작하도록 함
lsof -ti:5173 | xargs kill -9 2>/dev/null || true
sleep 1
if npx playwright test --project=setup --project=admin; then
  echo "✅ E2E 테스트 완료."
else
  echo "❌ E2E 테스트 실패."
  exit 1
fi

echo "🎉 pre-push 검사 완료!"
exit 0
